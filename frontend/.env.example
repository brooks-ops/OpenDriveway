# FastAPI base URL used by the browser app.
VITE_API_URL=http://localhost:8000

# Enables local/demo-only auth in the browser. Do not enable in production.
VITE_LOCAL_DEMO_MODE=true

# Supabase browser credentials for production auth. Leave empty only when VITE_LOCAL_DEMO_MODE=true.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Browser Google Maps key if a future Google Maps widget is enabled. OpenFreeMap does not require this.
VITE_GOOGLE_MAPS_API_KEY=
