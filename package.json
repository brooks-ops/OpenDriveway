{
  "name": "opendriveway",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "lint": "npm run lint --workspace frontend",
    "preview": "npm run preview --workspace frontend",
    "backend:dev": "uvicorn app.main:app --reload --app-dir backend",
    "backend:migrate": "PYTHONPATH=backend alembic -c backend/alembic.ini upgrade head",
    "backend:seed": "PYTHONPATH=backend python scripts/seed_demo.py",
    "backend:test": "PYTHONPATH=backend pytest -c backend/pytest.ini",
    "test:e2e": "npm run test:e2e --workspace frontend"
  }
}
