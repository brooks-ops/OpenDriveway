# Runtime label. Use local for development, test for automated tests, production in deployed environments.
APP_ENV=local

# Enables local/demo-only auth and service fallbacks. Do not enable in production.
LOCAL_DEMO_MODE=true

# Comma-separated browser origins allowed to call the API.
API_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Async SQLAlchemy PostgreSQL URL used by FastAPI and Alembic.
DATABASE_URL=postgresql+asyncpg://opendriveway:opendriveway@localhost:5432/opendriveway

# Supabase project URL for production authentication. Leave empty only when LOCAL_DEMO_MODE=true.
SUPABASE_URL=

# Supabase JWT audience. Supabase defaults to authenticated.
SUPABASE_JWT_AUDIENCE=authenticated

# Stripe secret key for Stripe Connect. Leave empty only when LOCAL_DEMO_MODE=true.
STRIPE_SECRET_KEY=

# Stripe Connect redirects. In demo mode the API returns STRIPE_CONNECT_RETURN_URL directly.
STRIPE_CONNECT_REFRESH_URL=http://localhost:5173/dashboard/host
STRIPE_CONNECT_RETURN_URL=http://localhost:5173/dashboard/host

# Server-side Google Maps API key for geocoding. Leave empty only when LOCAL_DEMO_MODE=true.
GOOGLE_MAPS_API_KEY=
