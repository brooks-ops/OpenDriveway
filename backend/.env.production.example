# OpenDriveway backend production environment.
# Copy these values into your backend host's environment settings.

APP_ENV=production
LOCAL_DEMO_MODE=false

# Your deployed frontend origin. Do not include localhost in production.
API_CORS_ORIGINS=https://YOUR_FRONTEND_DOMAIN
FRONTEND_URL=https://YOUR_FRONTEND_DOMAIN

# Production Postgres database used by FastAPI/Alembic.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DATABASE

# Supabase Auth.
SUPABASE_URL=https://odciideyuiltpqdsqenk.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated

# Leave Stripe off for the initial non-payment MVP launch.
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_REFRESH_URL=https://YOUR_FRONTEND_DOMAIN/dashboard/host
STRIPE_CONNECT_RETURN_URL=https://YOUR_FRONTEND_DOMAIN/dashboard/host
STRIPE_PLATFORM_FEE_BPS=1000

# Server-side geocoding key.
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
